# Bu faylni .env.local deb nusxalang va qiymatlarni o'zgartiring.
# Copy this file to .env.local and change the values.

# ---------------------------- Admin panel ----------------------------
# Admin panelga kirish uchun login (foydalanuvchi nomi)
ADMIN_USERNAME=admin

# Admin parol — tizimga kirish uchun
ADMIN_PASSWORD=admin123

# Sessiya imzosi uchun maxfiy kalit (uzun, tasodifiy satr qo'ying)
# Session signing secret — use a long random string
ADMIN_SESSION_SECRET=please-change-this-to-a-long-random-secret

# ------------------------------ Supabase ------------------------------
# Supabase dashboard → Project Settings → API dan oling.
# Project URL (masalan: https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# service_role kaliti — TO'LIQ HUQUQLI, MAXFIY. Faqat serverda ishlatiladi,
# hech qachon brauzerga/frontendga chiqmaydi. Vercel'da ham "Environment
# Variables" bo'limiga qo'shiladi (NEXT_PUBLIC_ prefiksisiz!).
# ⚠️ Bu yerga HAQIQIY kalitni yozmang — u faqat .env.local (git'ga tushmaydi) da bo'lsin.
SUPABASE_SERVICE_ROLE_KEY=
